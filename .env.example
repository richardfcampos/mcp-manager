# Copy this file to .env and fill in real values. .env is gitignored.

# 32-byte AES-256-GCM master key (base64), used to encrypt MCP secrets at
# rest. Generate one with: openssl rand -base64 32
MCP_MANAGER_MASTER_KEY=REPLACE_WITH_OUTPUT_OF_openssl_rand_-base64_32

# Absolute path to the workspace root to mount read-write into the
# container (used for project auto-discovery). Must be an existing
# directory on the host.
MCP_MANAGER_WORKSPACE_ROOT=/absolute/path/to/your/workspace

# Port the UI/API/gateway listens on (published on 0.0.0.0 (LAN-accessible)).
PORT=7788

# URL alcançável do gateway, gravada nos configs dos projetos. Para acesso
# de outra máquina na LAN, use o nome/host que ela resolve (ex.: http://intel:7788).
MCP_MANAGER_PUBLIC_BASE_URL=http://127.0.0.1:7788
