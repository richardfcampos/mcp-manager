{
  "name": "mcp-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Dockerized live MCP gateway with a web UI for managing MCP servers, consumers, and assignments.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/db/migrations && cp src/db/migrations/*.sql dist/db/migrations/",
    "build:web": "vite build --config web/vite.config.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run src",
    "test:integration": "vitest run test/integration"
  },
  "dependencies": {
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.9.1",
    "express": "^4.21.2",
    "smol-toml": "^1.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "postcss": "^8.5.16",
    "prettier": "^3.5.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^3.0.9"
  }
}
